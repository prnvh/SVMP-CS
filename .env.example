# App
APP_NAME=SVMP
APP_ENV=development
LOG_LEVEL=INFO
PORT=8000

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGODB_DB_NAME=svmp
MONGODB_SESSION_COLLECTION=session_state
MONGODB_KB_COLLECTION=knowledge_base
MONGODB_GOVERNANCE_COLLECTION=governance_logs

# OpenAI
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# WhatsApp Cloud API
WHATSAPP_TOKEN=EAAxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_VERIFY_TOKEN=your_own_secret_string

# Optional ops / escalation
SVMP_OPS_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/OPS/CHANNEL

# Runtime defaults
DEBOUNCE_MS=2500
SIMILARITY_THRESHOLD=0.75
WORKFLOW_B_INTERVAL_SECONDS=1
WORKFLOW_C_INTERVAL_HOURS=24

# Demo / fallback identity
DEFAULT_DOMAIN_ID=customer_support
DEFAULT_CLIENT_ID=whatsapp_official
