APP_NAME=SVMP
APP_ENV=development
LOG_LEVEL=INFO
PORT=8000

MONGODB_DB_NAME=svmp
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
MONGODB_SESSION_COLLECTION=session_state
MONGODB_KB_COLLECTION=knowledge_base
MONGODB_GOVERNANCE_COLLECTION=governance_logs
MONGODB_TENANTS_COLLECTION=tenants
MONGODB_TENANT_MEMBERSHIPS_COLLECTION=tenant_memberships
MONGODB_BILLING_SUBSCRIPTIONS_COLLECTION=billing_subscriptions
MONGODB_INTEGRATION_STATUS_COLLECTION=integration_status
MONGODB_AUDIT_LOGS_COLLECTION=audit_logs
MONGODB_PROVIDER_EVENTS_COLLECTION=provider_events

OPENAI_API_KEY=replace-with-openai-api-key
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini
USE_OPENAI_MATCHER=true
OPENAI_SHADOW_MODE=false
OPENAI_MATCHER_CANDIDATE_LIMIT=8

# Fallback provider used only when a session has no stored provider yet.
# In normal operation, outbound replies follow the inbound session provider.
WHATSAPP_PROVIDER=meta

# Public URL providers call when sending webhooks. Set this behind tunnels/proxies
# so Twilio signature verification uses the same URL Twilio signed.
WEBHOOK_PUBLIC_BASE_URL=https://your-svmp-domain.example

# Meta WhatsApp Business credentials.
WHATSAPP_TOKEN=replace-with-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-meta-phone-number-id
WHATSAPP_VERIFY_TOKEN=replace-with-meta-verify-token
META_APP_SECRET=replace-with-meta-app-secret

# Twilio WhatsApp Sandbox / virtual demo credentials.
TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Only use normalized webhooks for trusted internal tests/tools.
ALLOW_NORMALIZED_WEBHOOKS=false
NORMALIZED_WEBHOOK_SECRET=replace-with-internal-webhook-secret

DEBOUNCE_MS=2500
SIMILARITY_THRESHOLD=0.75
WORKFLOW_B_INTERVAL_SECONDS=1
WORKFLOW_B_PROCESSING_LOCK_TIMEOUT_SECONDS=300
WORKFLOW_C_INTERVAL_HOURS=24

# Customer portal auth and billing. Keep auth disabled until Clerk is wired.
# Use trusted_headers only behind a trusted local/staging proxy.
DASHBOARD_AUTH_MODE=disabled
DASHBOARD_APP_URL=https://app.svmpsystems.com
DASHBOARD_CORS_ORIGINS=https://app.svmpsystems.com
CLERK_ISSUER=https://your-clerk-issuer.example
CLERK_JWKS_URL=https://your-clerk-jwks.example/.well-known/jwks.json
CLERK_AUDIENCE=replace-with-clerk-audience
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
STRIPE_PRICE_ID=replace-with-stripe-price-id
